# Build artefacts
/bin/
/tmp/
*.log

# Generated by templ - never commit (regenerated by `make generate`).
*_templ.go

# Generated by Tailwind - never commit (regenerated by `make css`).
/web/static/app.css
/web/static/app.*.css

# Standalone tailwindcss binary, downloaded by `make css-setup`.
/scripts/tailwindcss

# Go test / coverage output
*.test
*.out
coverage.txt

# Editor / IDE
.vscode/
.idea/
*.swp
*.swo
*~

# Local secrets - the project doesn't currently use any, but if a future
# bridge to taskd or another service lands, env-shaped files should never
# be committed by accident.
.env
.env.*
!.env.example

# OS
.DS_Store
