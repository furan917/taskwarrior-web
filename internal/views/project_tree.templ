package views

import "fmt"

templ ProjectTree(roots []ProjectTreeNode) {
	<ul class="divide-y divide-zinc-200 rounded border border-zinc-200 bg-white dark:divide-zinc-800 dark:border-zinc-800 dark:bg-zinc-900">
		for _, node := range roots {
			@projectTreeNode(node, 0)
		}
	</ul>
}

templ projectTreeNode(node ProjectTreeNode, depth int) {
	if len(node.Children) == 0 {
		// Leaf — plain link row.
		<li>
			<a
				href={ templ.SafeURL("/project/" + node.FullName) }
				class={ "flex items-center justify-between px-3 py-2 text-sm hover:bg-zinc-50 dark:hover:bg-zinc-800 " + depthPaddingClass(depth) }
			>
				<span class="truncate text-zinc-800 dark:text-zinc-200">{ node.FullName }</span>
				@projectNodeMeta(node)
			</a>
		</li>
	} else {
		// Branch - open by default only at the top level so a deep
		// taxonomy (team.alpha.subteam.x.y) doesn't render fully expanded
		// as wall-of-text. Users can click into deeper branches as needed.
		// The `open?=...` attribute uses templ's boolean-attribute form:
		// emits `open` when the expression is true, omits it otherwise.
		<li>
			<details open?={ depth < defaultOpenDepth } class="group">
				<summary class={ "flex cursor-pointer list-none items-center justify-between px-3 py-2 text-sm hover:bg-zinc-50 [&::-webkit-details-marker]:hidden dark:hover:bg-zinc-800 " + depthPaddingClass(depth) }>
					<span class="flex items-center gap-1.5">
						<svg class="h-3 w-3 shrink-0 text-zinc-400 transition-transform group-open:rotate-90 dark:text-zinc-500" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
							<path fill-rule="evenodd" d="M7.21 14.77a.75.75 0 01.02-1.06L11.168 10 7.23 6.29a.75.75 0 111.04-1.08l4.5 4.25a.75.75 0 010 1.08l-4.5 4.25a.75.75 0 01-1.06-.02z" clip-rule="evenodd"></path>
						</svg>
						if node.HasOwnTasks {
							<a
								href={ templ.SafeURL("/project/" + node.FullName) }
								class="font-medium text-zinc-800 hover:underline dark:text-zinc-200"
								onClick="event.stopPropagation()"
							>{ node.FullName }</a>
						} else {
							<span class="font-medium text-zinc-800 dark:text-zinc-200">{ node.FullName }</span>
						}
					</span>
					@projectNodeMeta(node)
				</summary>
				<ul class="border-t border-zinc-100 dark:border-zinc-800">
					for _, child := range node.Children {
						@projectTreeNode(child, depth+1)
					}
				</ul>
			</details>
		</li>
	}
}

// projectNodeMeta renders the right-hand stat cluster: pending count badge,
// optional % complete badge, and optional avg age hint.
templ projectNodeMeta(node ProjectTreeNode) {
	<span class="ml-2 flex shrink-0 items-center gap-1.5">
		if node.AvgAgeDays() > 0 {
			<span class="text-[11px] text-zinc-400 dark:text-zinc-500">{ formatAge(node.AvgAgeDays()) }</span>
		}
		if node.TotalCompleted > 0 {
			<span class={ percentBadgeClass(node.PercentComplete()) }>{ fmt.Sprintf("%d%%", node.PercentComplete()) }</span>
		}
		<span class="inline-flex items-center rounded bg-zinc-100 px-2 py-0.5 text-xs font-medium text-zinc-700 dark:bg-zinc-800 dark:text-zinc-200">{ fmt.Sprintf("%d", node.TotalCount) }</span>
	</span>
}

func percentBadgeClass(pct int) string {
	base := "inline-flex items-center rounded px-2 py-0.5 text-xs font-medium "
	switch {
	case pct >= 80:
		return base + "bg-emerald-100 text-emerald-700 dark:bg-emerald-900/40 dark:text-emerald-300"
	case pct >= 40:
		return base + "bg-amber-100 text-amber-700 dark:bg-amber-900/40 dark:text-amber-300"
	default:
		return base + "bg-zinc-100 text-zinc-500 dark:bg-zinc-800 dark:text-zinc-400"
	}
}

func formatAge(days float64) string {
	switch {
	case days < 1:
		return "< 1d"
	case days < 14:
		return fmt.Sprintf("%dd", int(days))
	case days < 60:
		return fmt.Sprintf("%dw", int(days/7))
	default:
		return fmt.Sprintf("%dmo", int(days/30))
	}
}

// defaultOpenDepth is the recursion depth up to (and including) which
// `<details>` branches start expanded. depth=0 is the root; depth=1 is
// "first nested level". Anything deeper renders closed so a 5-level
// taxonomy doesn't paint the page on load.
const defaultOpenDepth = 1

// depthPaddingClass returns a Tailwind left-padding utility keyed off
// recursion depth. Depths are switch-cased so Tailwind's JIT scanner sees
// every class as a literal string at build time (a fmt.Sprintf-built class
// would never make it into the generated CSS). Depths beyond 5 are clamped
// to pl-28 - real project taxonomies rarely exceed 6 levels and clamping
// is preferable to silently dropping indentation past the cap.
//
// Replaces the previous inline `style={ ... }` hatch (the only such inline
// style in the codebase) so CSP `style-src 'unsafe-inline'` stays
// defence-in-depth rather than load-bearing.
func depthPaddingClass(depth int) string {
	switch depth {
	case 0:
		return ""
	case 1:
		return "pl-8"
	case 2:
		return "pl-12"
	case 3:
		return "pl-16"
	case 4:
		return "pl-20"
	case 5:
		return "pl-24"
	default:
		return "pl-28"
	}
}
