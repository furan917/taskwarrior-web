package views

// navTopLinks is the single source of truth for primary nav destinations.
// Both the desktop bar and the mobile drawer range over this; add a page once here.
var navTopLinks = []struct {
	Href  string
	Label string
	Key   string
}{
	{"/ready", "Ready", "ready"},
	{"/next", "Next", "next"},
	{"/agenda", "Agenda", "agenda"},
	{"/calendar", "Calendar", "calendar"},
	{"/browse", "Browse", "browse"},
	{"/stats", "Stats", "stats"},
}

templ Nav(active, activeContext string, contexts []NamedContext, builtinReports, customReports []string) {
	<nav class="mb-6 border-b border-zinc-200 pb-3 dark:border-zinc-800">
		<div class="flex items-center gap-2">
			// Hamburger – mobile only
			<button
				type="button"
				id="mobile-nav-open"
				class="inline-flex h-8 w-8 shrink-0 items-center justify-center rounded text-zinc-500 hover:bg-zinc-100 hover:text-zinc-900 focus:outline-none focus:ring-2 focus:ring-blue-500 sm:hidden dark:text-zinc-400 dark:hover:bg-zinc-800 dark:hover:text-zinc-100"
				aria-label="Open navigation"
				aria-controls="mobile-nav-drawer"
				aria-expanded="false"
			>
				<svg class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24" aria-hidden="true">
					<line x1="3" y1="6" x2="21" y2="6"></line>
					<line x1="3" y1="12" x2="21" y2="12"></line>
					<line x1="3" y1="18" x2="21" y2="18"></line>
				</svg>
			</button>
			// Desktop links – hidden on mobile
			<div class="hidden items-center gap-1 sm:flex">
				for _, l := range navTopLinks {
					@navLink(l.Href, l.Label, active == l.Key)
				}
				@moreMenu(active, builtinReports, customReports)
			</div>
			// Right actions – always visible. Active indicator is last so it sits at
			// the far-right edge; its dropdown uses right-0 which only works correctly
			// when the trigger is flush with the viewport's right boundary.
			<div class="ml-auto flex shrink-0 items-center gap-2 pr-0.5 sm:pr-0">
				@contextPill(activeContext, contexts)
				<button
					type="button"
					hx-post="/undo"
					hx-confirm="Undo the last change?"
					hx-swap="none"
					class="rounded border border-zinc-300 px-3 py-1.5 text-sm font-medium text-zinc-700 hover:bg-zinc-100 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 dark:border-zinc-600 dark:text-zinc-300 dark:hover:bg-zinc-800 dark:focus:ring-offset-zinc-950"
					title="Undo last change"
					aria-label="Undo"
				>
					Undo
				</button>
				<button
					type="button"
					hx-get="/forms/add"
					hx-target="#modal"
					class="rounded bg-blue-600 px-3 py-1.5 text-sm font-medium text-white shadow-sm hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 dark:focus:ring-offset-zinc-950"
				>
					+ Add Task
				</button>
				<div
					id="active-indicator"
					hx-get="/partials/active-indicator"
					hx-trigger="load, every 30s, refresh from:body"
					hx-swap="innerHTML"
				></div>
			</div>
		</div>
	</nav>
	@mobileNavDrawer(active, builtinReports, customReports)
}

// mobileNavDrawer is the slide-out panel for mobile. It reuses navTopLinks plus
// the same More-menu sections (flat, no nested dropdown) so there is one list
// of destinations to maintain.
// mobileNavDrawer is a <dialog> opened via showModal() from mobile_nav.js.
// Using <dialog> means the browser handles focus trap, ::backdrop, Esc,
// scroll lock, and inert-rest-of-page natively - no JS workarounds (the
// previous div-based drawer needed `mainEl.inert = true` which cascaded
// to descendant drawer markup and killed every click). Top-layer
// rendering means the dialog can live anywhere in the DOM tree; placing
// it inside Nav keeps the nav-related markup co-located.
templ mobileNavDrawer(active string, builtinReports, customReports []string) {
	<dialog
		id="mobile-nav-drawer"
		class="bg-white shadow-xl dark:bg-zinc-900 backdrop:bg-black/50"
		aria-label="Site navigation"
	>
		<div data-drawer-panel class="flex h-full flex-col">
			<div class="flex items-center justify-between border-b border-zinc-200 px-4 py-3 dark:border-zinc-800">
				<span class="text-sm font-semibold text-zinc-900 dark:text-zinc-100">Menu</span>
				<button
					type="button"
					id="mobile-nav-close"
					class="inline-flex h-7 w-7 items-center justify-center rounded text-zinc-400 hover:bg-zinc-100 hover:text-zinc-900 focus:outline-none focus:ring-2 focus:ring-blue-500 dark:hover:bg-zinc-800 dark:hover:text-zinc-100"
					aria-label="Close navigation"
				>
					<svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24" aria-hidden="true">
						<line x1="18" y1="6" x2="6" y2="18"></line>
						<line x1="6" y1="6" x2="18" y2="18"></line>
					</svg>
				</button>
			</div>
			<div class="flex-1 overflow-y-auto px-3 py-3">
				<div class="space-y-0.5">
					for _, l := range navTopLinks {
						@drawerNavLink(l.Href, l.Label, active == l.Key)
					}
				</div>
				<div class="mt-3 border-t border-zinc-200 pt-3 dark:border-zinc-800">
					@drawerSectionLabel("Lookups")
					<div class="space-y-0.5">
						@drawerNavLink("/contexts", "Contexts", active == "contexts")
						@drawerNavLink("/done", "Done", active == "done")
						@drawerNavLink("/forecast", "Forecast", active == "forecast")
						@drawerNavLink("/timesheet", "Timesheet", active == "timesheet")
					</div>
				</div>
				if len(builtinReports) > 0 {
					<div class="mt-3 border-t border-zinc-200 pt-3 dark:border-zinc-800">
						@drawerSectionLabel("Built-in")
						<div class="space-y-0.5">
							for _, name := range builtinReports {
								@drawerNavLink("/r/"+name, reportDisplayLabel(name), active == "r-"+name)
							}
						</div>
					</div>
				}
				if len(customReports) > 0 {
					<div class="mt-3 border-t border-zinc-200 pt-3 dark:border-zinc-800">
						@drawerSectionLabel("Custom")
						<div class="space-y-0.5">
							for _, name := range customReports {
								@drawerNavLink("/r/"+name, reportDisplayLabel(name), active == "r-"+name)
							}
						</div>
					</div>
				}
			</div>
		</div>
	</dialog>
}

templ drawerNavLink(href, label string, active bool) {
	if active {
		<a href={ templ.SafeURL(href) } class="flex items-center rounded-md bg-zinc-900 px-3 py-2 text-sm font-medium text-white dark:bg-zinc-100 dark:text-zinc-900">{ label }</a>
	} else {
		<a href={ templ.SafeURL(href) } class="flex items-center rounded-md px-3 py-2 text-sm font-medium text-zinc-700 hover:bg-zinc-100 dark:text-zinc-200 dark:hover:bg-zinc-800">{ label }</a>
	}
}

templ drawerSectionLabel(label string) {
	<div class="mb-1 px-3 text-[10px] font-semibold uppercase tracking-wider text-zinc-400 dark:text-zinc-500">{ label }</div>
}

templ navLink(href, label string, active bool) {
	if active {
		<a href={ templ.SafeURL(href) } class="shrink-0 rounded bg-zinc-900 px-3 py-1.5 text-sm font-medium text-white dark:bg-zinc-100 dark:text-zinc-900">{ label }</a>
	} else {
		<a href={ templ.SafeURL(href) } class="shrink-0 rounded px-3 py-1.5 text-sm font-medium text-zinc-600 hover:bg-zinc-100 dark:text-zinc-300 dark:hover:bg-zinc-800">{ label }</a>
	}
}

// moreMenu groups the lower-frequency reports (Forecast, Done) plus the
// curated TW built-ins and any user-defined reports under a single dropdown
// to keep the top-level nav scannable. Sections are only rendered if non-
// empty so a user with no custom reports doesn't see an orphan header.
//
// Open state is driven by the same generic [data-popover-wrap] / data-open
// machinery that powers the context pill (see web/static/js/context_pill.js).
templ moreMenu(active string, builtinReports, customReports []string) {
	<span class="relative inline-flex shrink-0" data-popover-wrap>
		<button
			type="button"
			class={ moreTriggerClass(moreActive(active)) }
			aria-haspopup="menu"
			aria-label="More reports"
			data-popover-trigger
		>
			<span>More</span>
			<span class="text-xs opacity-60" aria-hidden="true">▾</span>
		</button>
		<div
			class="absolute left-0 top-full z-30 mt-1 hidden min-w-52 rounded-md border border-zinc-200 bg-white shadow-lg dark:border-zinc-700 dark:bg-zinc-900"
			role="menu"
			data-popover-menu
		>
			<div class="max-h-96 overflow-y-auto py-1 text-sm">
				@moreSectionHeader("Lookups")
				@moreMenuLink("/contexts", "Contexts", active == "contexts")
				@moreMenuLink("/done", "Done", active == "done")
				@moreMenuLink("/forecast", "Forecast", active == "forecast")
				@moreMenuLink("/timesheet", "Timesheet", active == "timesheet")
				if len(builtinReports) > 0 {
					@moreSectionHeader("Built-in")
					for _, name := range builtinReports {
						@moreMenuLink("/r/"+name, reportDisplayLabel(name), active == "r-"+name)
					}
				}
				if len(customReports) > 0 {
					@moreSectionHeader("Custom")
					for _, name := range customReports {
						@moreMenuLink("/r/"+name, reportDisplayLabel(name), active == "r-"+name)
					}
				}
			</div>
		</div>
	</span>
}

// moreActive flips the More trigger's active styling when any item inside
// the dropdown matches the current page. This mirrors the navLink active
// state so users always see "you are inside this menu".
func moreActive(active string) bool {
	if active == "forecast" || active == "done" || active == "timesheet" || active == "contexts" {
		return true
	}
	if len(active) > 2 && active[:2] == "r-" {
		return true
	}
	return false
}

func moreTriggerClass(active bool) string {
	if active {
		return "shrink-0 inline-flex items-center gap-1 rounded bg-zinc-900 px-3 py-1.5 text-sm font-medium text-white dark:bg-zinc-100 dark:text-zinc-900"
	}
	return "shrink-0 inline-flex items-center gap-1 rounded px-3 py-1.5 text-sm font-medium text-zinc-600 hover:bg-zinc-100 dark:text-zinc-300 dark:hover:bg-zinc-800"
}

templ moreSectionHeader(label string) {
	<div class="px-3 pb-1 pt-2 text-[10px] font-semibold uppercase tracking-wider text-zinc-400 dark:text-zinc-500">{ label }</div>
}

// moreMenuLink is a plain anchor (not htmx) that closes the popover via the
// generic data-popover-item delegation before navigating. Using <a> rather
// than a button means middle-click / cmd-click / "open in new tab" all
// behave correctly.
templ moreMenuLink(href, label string, active bool) {
	<a
		href={ templ.SafeURL(href) }
		class={ moreMenuLinkClass(active) }
		role="menuitem"
		data-popover-item
	>
		{ label }
		if active {
			<span class="ml-2 text-xs" aria-hidden="true">✓</span>
		}
	</a>
}

func moreMenuLinkClass(active bool) string {
	if active {
		return "block px-3 py-1.5 text-sm font-medium text-zinc-900 bg-zinc-100 dark:bg-zinc-800 dark:text-zinc-100"
	}
	return "block px-3 py-1.5 text-sm text-zinc-700 hover:bg-zinc-100 dark:text-zinc-200 dark:hover:bg-zinc-800"
}

// contextPill renders the persistent-filter indicator + dropdown trigger. The
// pill switches between an inactive outline-only "all" affordance and a
// solid coloured-fill active state with a status dot, name, and one-click
// clear (×).
//
// Click handling lives in context_pill.js (delegated): toggling [data-open="1"]
// on any [data-popover-wrap] opens its sibling dropdown; click-outside / Esc
// close it. Same primitive powers the More menu above.
templ contextPill(activeContext string, contexts []NamedContext) {
	<span class="relative inline-flex" data-popover-wrap>
		if activeContext != "" {
			@contextPillActive(activeContext)
		} else {
			@contextPillInactive()
		}
		@contextDropdown(activeContext, contexts)
	</span>
}

templ contextPillActive(name string) {
	<button
		type="button"
		class={ PillActiveClass(ColourForContext(name)) }
		aria-haspopup="menu"
		aria-label={ "Context: " + name }
		title={ "Context: " + name + " (click to switch)" }
		data-popover-trigger
	>
		<span class="relative flex h-2 w-2">
			<span class={ PillDotPingClass(ColourForContext(name)) } aria-hidden="true"></span>
			<span class={ PillDotClass(ColourForContext(name)) } aria-hidden="true"></span>
		</span>
		<svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
			<polygon points="22 3 2 3 10 12.46 10 19 14 21 14 12.46 22 3"></polygon>
		</svg>
		<span>{ name }</span>
		<span
			role="button"
			tabindex="0"
			hx-post={ contextSetURL }
			hx-vals='{"name":""}'
			hx-swap="none"
			class="ml-1 cursor-pointer opacity-60 hover:opacity-100"
			aria-label="Clear context"
			title="Clear context"
			data-context-clear
		>×</span>
	</button>
}

templ contextPillInactive() {
	<button
		type="button"
		class="context-pill inline-flex items-center gap-1.5 rounded border border-zinc-300 py-1 px-2.5 text-sm font-medium text-zinc-500 hover:bg-zinc-100 dark:border-zinc-600 dark:text-zinc-400 dark:hover:bg-zinc-800"
		aria-haspopup="menu"
		aria-label="Context: none"
		title="Click to choose a context"
		data-popover-trigger
	>
		<svg class="h-3.5 w-3.5 text-zinc-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
			<polygon points="22 3 2 3 10 12.46 10 19 14 21 14 12.46 22 3"></polygon>
		</svg>
		<span>all</span>
		<span class="text-xs opacity-60" aria-hidden="true">▾</span>
	</button>
}

// contextDropdown is the sibling menu shown when the wrapper carries
// [data-open="1"]. CSS selector picks that up; absent that attribute the
// menu stays display:none. Defined here so the wrapper plus menu are
// co-located and the JS can treat them as one unit.
templ contextDropdown(activeContext string, contexts []NamedContext) {
	<div
		class="absolute left-0 top-full z-30 mt-1 hidden min-w-44 rounded-md border border-zinc-200 bg-white shadow-lg sm:left-auto sm:right-0 dark:border-zinc-700 dark:bg-zinc-900"
		role="menu"
		data-popover-menu
	>
		<div class="max-h-72 overflow-y-auto py-1 text-sm">
			@contextMenuItem("", "(none)", activeContext == "")
			for _, c := range contexts {
				@contextMenuItem(c.Name, c.Name, c.Name == activeContext)
			}
		</div>
		<div class="border-t border-zinc-200 dark:border-zinc-700">
			<a href="/contexts" class="flex w-full items-center px-3 py-1.5 text-[11px] text-zinc-500 hover:bg-zinc-50 hover:text-zinc-700 dark:text-zinc-400 dark:hover:bg-zinc-800 dark:hover:text-zinc-300">Manage contexts…</a>
		</div>
	</div>
}

templ contextMenuItem(value, label string, active bool) {
	<button
		type="button"
		role="menuitem"
		hx-post={ contextSetURL }
		hx-vals={ contextMenuVals(value) }
		hx-swap="none"
		class={ contextMenuItemClass(active) }
		data-popover-item
	>
		{ label }
		if active {
			<span class="ml-2 text-xs" aria-hidden="true">✓</span>
		}
	</button>
}
