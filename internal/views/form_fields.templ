package views

import (
	"strings"

	"github.com/furan917/taskwarrior-web/internal/tw"
)

// dateHelpTip is the per-field "?" disclosure that explains Taskwarrior's
// accepted date forms inline. Native <details>/<summary> handles the
// click-to-toggle so we don't need extra JS, and it's keyboard-accessible
// out of the box (Enter / Space toggles when the summary is focused).
//
// The popover is absolutely positioned below the summary; CSS classes on
// the summary itself hide the default disclosure triangle and style the
// "?" icon to match our zinc/blue palette in both light and dark mode.
templ dateHelpTip() {
	<details class="relative inline-block leading-none">
		<summary
			class="list-none cursor-help text-zinc-400 hover:text-zinc-700 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:rounded-full dark:text-zinc-500 dark:hover:text-zinc-200 [&::-webkit-details-marker]:hidden"
			aria-label="Date format help"
			title="Click for date format help"
		>
			<span class="inline-flex h-4 w-4 items-center justify-center rounded-full border border-current text-[10px] font-semibold">?</span>
		</summary>
		<div class="absolute left-0 top-full z-30 mt-1 w-64 rounded-md border border-zinc-200 bg-white p-3 text-xs leading-relaxed text-zinc-700 shadow-lg dark:border-zinc-700 dark:bg-zinc-900 dark:text-zinc-200">
			<p class="mb-1 font-semibold text-zinc-900 dark:text-zinc-100">Date formats</p>
			<dl class="space-y-1.5">
				<dt class="font-medium text-zinc-800 dark:text-zinc-100">Absolute</dt>
				<dd class="font-mono text-[11px] text-zinc-600 dark:text-zinc-300">2026-05-09<br/>2026-05-09T14:00</dd>
				<dt class="font-medium text-zinc-800 dark:text-zinc-100">Keywords</dt>
				<dd class="font-mono text-[11px] text-zinc-600 dark:text-zinc-300">tomorrow, today<br/>eom (end of month)<br/>eod, mon, tue, ...</dd>
				<dt class="font-medium text-zinc-800 dark:text-zinc-100">Relative offsets</dt>
				<dd class="font-mono text-[11px] text-zinc-600 dark:text-zinc-300">+2d, +1w, -3h<br/>due-3d (relative to due)<br/>scheduled+1w</dd>
			</dl>
			<p class="mt-2 text-[11px] text-zinc-500 dark:text-zinc-400">Or click a preset below the field.</p>
		</div>
	</details>
}

// recurHelpTip is the per-field "?" disclosure for the Recur input. Lists
// the duration forms Taskwarrior accepts. Mirrors dateHelpTip's structure
// so the two help popovers feel uniform.
templ recurHelpTip() {
	<details class="relative inline-block leading-none">
		<summary
			class="list-none cursor-help text-zinc-400 hover:text-zinc-700 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:rounded-full dark:text-zinc-500 dark:hover:text-zinc-200 [&::-webkit-details-marker]:hidden"
			aria-label="Recurrence format help"
			title="Click for recurrence format help"
		>
			<span class="inline-flex h-4 w-4 items-center justify-center rounded-full border border-current text-[10px] font-semibold">?</span>
		</summary>
		<div class="absolute left-0 top-full z-30 mt-1 w-64 rounded-md border border-zinc-200 bg-white p-3 text-xs leading-relaxed text-zinc-700 shadow-lg dark:border-zinc-700 dark:bg-zinc-900 dark:text-zinc-200">
			<p class="mb-1 font-semibold text-zinc-900 dark:text-zinc-100">Recurrence formats</p>
			<dl class="space-y-1.5">
				<dt class="font-medium text-zinc-800 dark:text-zinc-100">Keywords</dt>
				<dd class="font-mono text-[11px] text-zinc-600 dark:text-zinc-300">daily, weekly, monthly<br/>biweekly, fortnight<br/>quarterly, annually</dd>
				<dt class="font-medium text-zinc-800 dark:text-zinc-100">Duration</dt>
				<dd class="font-mono text-[11px] text-zinc-600 dark:text-zinc-300">1d, 2w, 1mo, 3y</dd>
				<dt class="font-medium text-zinc-800 dark:text-zinc-100">ISO 8601</dt>
				<dd class="font-mono text-[11px] text-zinc-600 dark:text-zinc-300">P7D, P1M, PT1H</dd>
			</dl>
			<p class="mt-2 text-zinc-500 dark:text-zinc-400">Pair with Until to stop spawning instances after a date.</p>
		</div>
	</details>
}

// datePresets renders a row of pill buttons under a date input. Clicking a
// pill fills the sibling input[name=target] and dispatches a bubbling input
// event so form_validation.js clears any red border on that field.
//
// Pure declarative markup: behaviour lives in date_presets.js, which delegates
// off [data-date-preset] at the document level. Strings here are passed
// straight to Taskwarrior, so they must be valid date tokens (see dateHelpTip
// for the accepted forms).
templ datePresets(target string, presets []string) {
	<div class="mt-1 flex flex-wrap gap-1">
		for _, p := range presets {
			<button
				type="button"
				data-date-preset
				data-target={ target }
				class="rounded border border-zinc-200 bg-zinc-50 px-1.5 py-0.5 font-mono text-[11px] text-zinc-600 hover:bg-zinc-100 hover:text-zinc-900 focus:outline-none focus:ring-2 focus:ring-blue-500 dark:border-zinc-700 dark:bg-zinc-800 dark:text-zinc-300 dark:hover:bg-zinc-700 dark:hover:text-zinc-100"
			>{ p }</button>
		}
	</div>
}

// taskForm holds the field values shared between add and edit modals.
// UDAs is name -> current value for any UDAs the user has set on this task;
// empty map (or nil) means no values pre-filled. The defs are passed into
// formFields separately because they're orthogonal data: defs come from the
// process-wide cache, values come from the task being edited.
//
// Depends is the list of UUIDs the user has selected as prerequisites for this
// task. Empty slice (or nil) renders no pills. The picker reads its candidate
// list from the allOpenTasks slice passed alongside formFields.
type taskForm struct {
	Description string
	Project     string
	Tags        string
	Due         string
	Wait        string
	Scheduled   string
	// Recur is a Taskwarrior duration expression ("weekly", "monthly",
	// "1mo", "P7D"). Empty means a one-off task. Until pairs with it as
	// the stop date for the recurring template.
	Recur string
	Until string
	// RecurrenceReadOnly disables the Recur and Until inputs. Set when
	// the modal is editing a recurring CHILD instance: TW accepts the
	// modify but the change is orphaned (siblings keep the parent's
	// schedule), so we render the fields read-only with a hint pointing
	// to the parent template instead.
	RecurrenceReadOnly bool
	UDAs               map[string]string
	Depends            []string
}

templ formFields(f taskForm, udas []tw.UDA, projects, tags []string, allOpenTasks []tw.Task) {
	<div class="flex flex-col gap-3 p-4">
		<label class="block text-sm">
			<span class="mb-1 block text-zinc-700 dark:text-zinc-300">Description</span>
			<input
				type="text"
				name="description"
				required
				autofocus
				value={ f.Description }
				class="w-full rounded border border-zinc-300 px-2 py-1.5 text-sm focus:border-blue-500 focus:outline-none dark:border-zinc-600 dark:bg-zinc-800 dark:text-zinc-100 dark:placeholder-zinc-500"
			/>
		</label>
		<div class="grid grid-cols-2 gap-3">
			<label class="block text-sm">
				<span class="mb-1 block text-zinc-700 dark:text-zinc-300">Project</span>
				@acField("project", f.Project, "work / home / team.alpha", "single", stringsToOptions(projects))
			</label>
			<label class="block text-sm">
				<span class="mb-1 block text-zinc-700 dark:text-zinc-300">Tags</span>
				@acField("tags", f.Tags, "comma, separated", "tokens", stringsToOptions(tags))
			</label>
			<label class="block text-sm">
				<div class="mb-1 flex items-center gap-1.5 text-zinc-700 dark:text-zinc-300">
					<span>Due</span>
					@dateHelpTip()
				</div>
				@dateInputWithPicker("due", f.Due, "+2d / tomorrow / 2026-05-09")
				@datePresets("due", []string{"today", "tomorrow", "+3d", "+1w", "+2w", "eom"})
			</label>
			<label class="block text-sm">
				<div class="mb-1 flex items-center gap-1.5 text-zinc-700 dark:text-zinc-300">
					<span>Wait</span>
					@dateHelpTip()
				</div>
				@dateInputWithPicker("wait", f.Wait, "+1d / due-7d")
				@datePresets("wait", []string{"tomorrow", "+1w", "due-7d", "due-3d"})
			</label>
			<label class="col-span-2 block text-sm">
				<div class="mb-1 flex items-center gap-1.5 text-zinc-700 dark:text-zinc-300">
					<span>Scheduled for start</span>
					@dateHelpTip()
				</div>
				@dateInputWithPicker("scheduled", f.Scheduled, "+3d / due-3d / 2026-05-15")
				@datePresets("scheduled", []string{"today", "tomorrow", "+3d", "due-3d", "due-1d"})
			</label>
			<label class="block text-sm">
				<div class="mb-1 flex items-center gap-1.5 text-zinc-700 dark:text-zinc-300">
					<span>Recur</span>
					@recurHelpTip()
				</div>
				if f.RecurrenceReadOnly {
					<input type="text" name="recur" value={ f.Recur } readonly tabindex="-1" class="w-full cursor-not-allowed rounded border border-zinc-200 bg-zinc-50 px-2 py-1.5 text-sm text-zinc-500 dark:border-zinc-700 dark:bg-zinc-800/60 dark:text-zinc-400"/>
				} else {
					<input type="text" name="recur" value={ f.Recur } placeholder="weekly / 1mo / blank for one-off" class="w-full rounded border border-zinc-300 px-2 py-1.5 text-sm focus:border-blue-500 focus:outline-none dark:border-zinc-600 dark:bg-zinc-800 dark:text-zinc-100 dark:placeholder-zinc-500"/>
					@datePresets("recur", []string{"weekly", "biweekly", "monthly", "quarterly", "annually"})
				}
			</label>
			<label class="block text-sm">
				<div class="mb-1 flex items-center gap-1.5 text-zinc-700 dark:text-zinc-300">
					<span>Until</span>
					@dateHelpTip()
				</div>
				if f.RecurrenceReadOnly {
					<input type="text" name="until" value={ f.Until } readonly tabindex="-1" class="w-full cursor-not-allowed rounded border border-zinc-200 bg-zinc-50 px-2 py-1.5 text-sm text-zinc-500 dark:border-zinc-700 dark:bg-zinc-800/60 dark:text-zinc-400"/>
				} else {
					@dateInputWithPicker("until", f.Until, "2027-01-01 / eoy")
					@datePresets("until", []string{"+3mo", "+6mo", "+1y", "eoy"})
				}
			</label>
			if f.RecurrenceReadOnly {
				<p class="col-span-2 -mt-2 text-xs text-zinc-500 dark:text-zinc-400">Recurrence belongs to the parent template - edit there to change schedule. Find it under More <span class="text-zinc-400">▾</span> Built-in <span class="text-zinc-400">▾</span> Recurring.</p>
			}
		</div>
		if len(udas) > 0 {
			<div class="grid grid-cols-2 gap-3">
				for _, u := range udas {
					@udaField(u, f.UDAs[u.Name])
				}
			</div>
		}
		@depPicker(f.Depends, allOpenTasks)
	</div>
}

// acOption is one row in a custom autocomplete dropdown. Value is what the
// form ultimately submits (or what the consumer event handler receives);
// Text is what the user sees and types against. They differ for the deps
// picker (Value=UUID, Text=description); for projects/tags they're equal.
type acOption struct {
	Value string
	Text  string
}

func stringsToOptions(ss []string) []acOption {
	out := make([]acOption, 0, len(ss))
	for _, s := range ss {
		out = append(out, acOption{Value: s, Text: s})
	}
	return out
}

// acField is the themed replacement for native <datalist>: a styled <input>
// followed by a <ul> dropdown the autocomplete IIFE in app.js opens, filters,
// and lets the user navigate with the keyboard or click. Modes:
//
//   - "single" - selecting an option replaces the input's value.
//   - "tokens" - selecting an option replaces the last comma-separated token
//     in the input (used for the comma-list Tags field).
//   - "deps"   - selecting an option dispatches autocomplete:select with
//     {value, text}; the dep-picker IIFE preventDefaults the event and adds
//     a pill instead of mutating the input. We don't render that container
//     here - depPicker has its own surrounding chrome.
templ acField(name, value, placeholder, mode string, options []acOption) {
	<div class="relative" data-ac data-ac-mode={ mode }>
		<input
			type="text"
			name={ name }
			value={ value }
			placeholder={ placeholder }
			autocomplete="off"
			class="w-full rounded border border-zinc-300 px-2 py-1.5 text-sm focus:border-blue-500 focus:outline-none dark:border-zinc-600 dark:bg-zinc-800 dark:text-zinc-100 dark:placeholder-zinc-500"
			data-ac-input
		/>
		@acList(options)
	</div>
}

templ acList(options []acOption) {
	<ul
		class="absolute left-0 right-0 z-30 mt-1 hidden max-h-60 overflow-y-auto rounded-md border border-zinc-200 bg-white py-1 text-sm shadow-lg dark:border-zinc-700 dark:bg-zinc-900"
		role="listbox"
		data-ac-list
	>
		for _, o := range options {
			<li
				class="cursor-pointer px-3 py-1.5 text-zinc-700 hover:bg-zinc-100 aria-[selected=true]:bg-blue-50 aria-[selected=true]:text-blue-900 dark:text-zinc-200 dark:hover:bg-zinc-800 dark:aria-[selected=true]:bg-blue-950/40 dark:aria-[selected=true]:text-blue-100"
				role="option"
				data-ac-value={ o.Value }
				data-ac-text={ o.Text }
			>{ o.Text }</li>
		}
	</ul>
}

// depPicker renders the multi-select dependency picker: existing selections as
// removable pills, an autocomplete-backed text input listing every open task
// by description, and a hidden field carrying the comma-separated UUID list
// the form submits. The JS IIFE in app.js (dep-picker) wires up Enter-to-add,
// click-to-remove, and the hidden-field sync.
//
// `current` is the list of UUIDs already attached to the task being edited
// (empty for the add modal). `allOpenTasks` is every pending/waiting task we
// could possibly depend on; we render their descriptions in the datalist so
// the user types text but the form submits UUIDs.
templ depPicker(current []string, allOpenTasks []tw.Task) {
	<div class="relative block text-sm" data-dep-picker data-ac data-ac-mode="deps">
		<span class="mb-1 block text-zinc-700 dark:text-zinc-300">Depends on</span>
		<div class="flex flex-wrap items-center gap-1.5 rounded border border-zinc-300 bg-white px-2 py-1.5 focus-within:border-blue-500 dark:border-zinc-600 dark:bg-zinc-800">
			<div class="dep-pills flex flex-wrap items-center gap-1.5">
				for _, uuid := range current {
					@depPill(uuid, depDescriptionFor(uuid, allOpenTasks))
				}
			</div>
			<input
				type="text"
				class="dep-input min-w-[10rem] flex-1 border-0 bg-transparent px-1 py-0.5 text-sm focus:outline-none dark:text-zinc-100 dark:placeholder-zinc-500"
				placeholder="Type a task description, press Enter…"
				autocomplete="off"
				aria-label="Add a dependency by typing a task description"
				data-ac-input
			/>
		</div>
		<input type="hidden" name="depends" class="dep-hidden" value={ strings.Join(current, ",") }/>
		@acList(depTaskOptions(allOpenTasks))
		// dep-pill-template is the canonical pill markup the JS dep-picker
		// IIFE clones at request time. Rendering once on the server keeps the
		// pill class string in one place (here) so the rendered initial pills
		// (depPill above) and the JS-cloned pills can't drift apart.
		//
		// TODO(next batch): update app.js's makePill() to clone this template
		// instead of constructing the same DOM nodes by hand. Until then the
		// JS keeps the literal class string in app.js and this template is
		// purely declarative.
		<template id="dep-pill-template">
			@depPill("", "")
		</template>
	</div>
}

func depTaskOptions(allOpenTasks []tw.Task) []acOption {
	out := make([]acOption, 0, len(allOpenTasks))
	for _, t := range allOpenTasks {
		if t.UUID == "" {
			continue
		}
		out = append(out, acOption{Value: t.UUID, Text: t.Description})
	}
	return out
}

// depPill is one selected dependency rendered as a removable chip. The
// data-uuid attribute is the load-bearing piece - the JS sync reads it back
// when regenerating the hidden field after a removal.
templ depPill(uuid, description string) {
	<span class="dep-pill inline-flex items-center gap-1 rounded bg-zinc-100 px-2 py-0.5 text-xs text-zinc-700 dark:bg-zinc-700 dark:text-zinc-200" data-uuid={ uuid }>
		<span class="dep-pill-label">{ depPillLabel(uuid, description) }</span>
		<button
			type="button"
			class="dep-pill-remove text-zinc-500 hover:text-zinc-900 dark:text-zinc-400 dark:hover:text-zinc-100"
			aria-label="Remove dependency"
			title="Remove"
		>×</button>
	</span>
}

// udaField renders one UDA as a label + input. If the UDA has a value
// allowlist (uda.<name>.values=...) we render a <select> so the user can only
// pick a valid option; otherwise a type-appropriate <input>. Name is
// "uda_<name>" so handlers can pluck values back out via r.FormValue without
// colliding with built-in field names.
templ udaField(u tw.UDA, value string) {
	<label class="block text-sm">
		<span class="mb-1 block text-zinc-700 dark:text-zinc-300">{ udaLabel(u) }</span>
		if len(u.Values) > 0 {
			<select
				name={ "uda_" + u.Name }
				class="w-full rounded border border-zinc-300 px-2 py-1.5 text-sm focus:border-blue-500 focus:outline-none dark:border-zinc-600 dark:bg-zinc-800 dark:text-zinc-100"
			>
				<option value="" selected?={ value == "" }>(none)</option>
				for _, opt := range u.Values {
					<option value={ opt } selected?={ value == opt }>{ opt }</option>
				}
			</select>
		} else {
			<input
				type={ udaInputType(u.Type) }
				name={ "uda_" + u.Name }
				value={ value }
				placeholder={ udaPlaceholder(u.Type) }
				class="w-full rounded border border-zinc-300 px-2 py-1.5 text-sm focus:border-blue-500 focus:outline-none dark:border-zinc-600 dark:bg-zinc-800 dark:text-zinc-100 dark:placeholder-zinc-500"
			/>
		}
	</label>
}

// dateInputWithPicker renders a text input with a small calendar
// icon to its right. The icon opens a flatpickr picker (wired by
// form_date_picker.js via the wrap-mode contract: [data-fp-date] on
// the wrapper, [data-input] on the field, [data-toggle] on the
// button). Click on the input itself is left as plain typing -
// allowing Taskwarrior relative-date entry like "+2d" or "tomorrow"
// alongside the ISO date the picker produces.
templ dateInputWithPicker(name, value, placeholder string) {
	<div class="relative" data-fp-date>
		<input
			type="text"
			name={ name }
			value={ value }
			placeholder={ placeholder }
			data-input
			class="w-full rounded border border-zinc-300 px-2 py-1.5 pr-9 text-sm focus:border-blue-500 focus:outline-none dark:border-zinc-600 dark:bg-zinc-800 dark:text-zinc-100 dark:placeholder-zinc-500"
		/>
		<button
			type="button"
			data-toggle
			class="absolute right-1 top-1/2 -translate-y-1/2 inline-flex h-7 w-7 items-center justify-center rounded text-zinc-400 hover:bg-zinc-100 hover:text-zinc-700 focus:outline-none focus:ring-2 focus:ring-blue-500 dark:hover:bg-zinc-800 dark:hover:text-zinc-200"
			aria-label="Pick date"
			title="Pick date"
		>
			<svg class="h-4 w-4" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
				<rect x="3" y="4" width="14" height="13" rx="2"></rect>
				<path d="M3 8h14"></path>
				<path d="M7 2v4"></path>
				<path d="M13 2v4"></path>
			</svg>
		</button>
	</div>
}
